# Deploy params for Deploy.s.sol / DeployAll.s.sol (all optional; defaults target Anvil).
# Deployer key — also the founding president. Use a funded key for Sepolia/mainnet.
# (Anvil default account #0 is used if unset — local only, never on a real network.)
DEPLOYER_PK=

# Economic + founding parameters.
POST_FEE_WEI=100000000000000        # 0.0001 ETH
CITIZENSHIP_WEI=3000000000000000    # 0.003 ETH
CITIZEN_TARGET=10                   # citizens to end the founding phase (T)
TIMELOCK_DELAY=172800               # 2 days, for the governance timelock (DeployAll)
GOVERNANCE=                         # address granted GOVERNANCE_ROLE (blank = none)

# Networks (used by forge script --rpc-url and the Sepolia GitHub Action).
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# ETHERSCAN_API_KEY=                # optional, for `forge ... --verify`
