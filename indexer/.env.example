# The Bitchan/Republic contract to index. dev.sh writes the live value into
# .env.local; for Sepolia use the deployed Republic address.
BITCHAN_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# RPC per chain id (Ponder convention: PONDER_RPC_URL_<chainId>).
# Local Anvil (31337):
PONDER_RPC_URL_31337=http://127.0.0.1:8545
# Sepolia (11155111) — set when indexing the live deployment:
# PONDER_RPC_URL_11155111=https://ethereum-sepolia-rpc.publicnode.com
