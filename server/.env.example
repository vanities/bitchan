# Engagement + media server (Bun + Hono).
# HTTP port.
PORT=42070
# sqlite db for signed engagement (likes/reposts/follows).
DB_PATH=engagement.sqlite
# Where uploaded media is stored (dev placeholder for Arweave).
MEDIA_DIR=media
# Max upload size in bytes.
MAX_MEDIA_BYTES=26214400
# Chain id used in the EIP-712 domain when verifying signatures
# (31337 = Anvil, 11155111 = Sepolia).
CHAIN_ID=31337
