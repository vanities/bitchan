# Address of the deployed Bitchan contract (defaults to Anvil's first-deploy address)
VITE_BITCHAN_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Ponder GraphQL endpoint
VITE_PONDER_URL=http://localhost:42069/graphql

# WalletConnect Cloud project id — required only for mobile/WalletConnect wallets.
# Injected wallets (MetaMask on desktop) work without it.
VITE_WALLETCONNECT_PROJECT_ID=

# Gasless engagement server (likes/reposts/follows via signed messages)
VITE_ENGAGEMENT_URL=http://localhost:42070
