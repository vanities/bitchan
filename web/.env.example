# ── Network ───────────────────────────────────────────────────────────────
# Which chain the app targets. Leave unset (or "anvil") for the local dev chain;
# set to "sepolia" to point at the live Sepolia deployment.
VITE_CHAIN=anvil
# RPC used when VITE_CHAIN=sepolia (defaults to a public Sepolia node).
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── Contracts ─────────────────────────────────────────────────────────────
# Republic address. Defaults per-network (Anvil first-deploy / the Sepolia deploy),
# so you only set this to override. dev.sh writes the local value into .env.local.
VITE_BITCHAN_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# Active presidential election (per-instance; blank = none). seed-election.sh sets it.
VITE_ELECTION_ADDRESS=

# ── Off-chain / backend ─────────────────────────────────────────────────────
# Convex backend (timeline read model + gasless engagement). Run `bunx convex dev`
# to create the project + get this URL. Replacing the Ponder/engagement services below.
VITE_CONVEX_URL=
# Ponder GraphQL endpoint (legacy read model; being replaced by Convex).
VITE_PONDER_URL=http://localhost:42069/graphql
# Gasless engagement server (signed likes/reposts/follows) + media.
VITE_ENGAGEMENT_URL=http://localhost:42070
# Media base URL (defaults to VITE_ENGAGEMENT_URL).
VITE_MEDIA_URL=

# ── Wallets ─────────────────────────────────────────────────────────────────
# WalletConnect Cloud project id — only needed for mobile/WalletConnect wallets.
# Injected wallets (MetaMask on desktop) work without it.
VITE_WALLETCONNECT_PROJECT_ID=
