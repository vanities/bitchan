# ── Network ───────────────────────────────────────────────────────────────
# Which chain the app targets. The app runs against "sepolia" (the Convex backend
# indexes Sepolia, not a local chain). "anvil" is only useful for raw contract work
# and has no backend, so the feed will be empty.
VITE_CHAIN=sepolia
# RPC used when VITE_CHAIN=sepolia (defaults to a public Sepolia node).
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── Contracts ─────────────────────────────────────────────────────────────
# Republic address. Defaults per-network (Anvil first-deploy / the Sepolia deploy)
# in src/lib/contract.ts, so leave unset unless overriding.
# VITE_BITCHAN_ADDRESS=
# Active presidential election (per-instance; blank = none). seed-election.sh sets it on anvil.
VITE_ELECTION_ADDRESS=

# ── Backend (Convex) ────────────────────────────────────────────────────────
# Convex: timeline read model + gasless engagement. Run `bunx convex dev` to
# create the project and write this value into .env.local.
VITE_CONVEX_URL=

# ── Media ───────────────────────────────────────────────────────────────────
# Media is stored in Convex and served from the Convex HTTP domain (.convex.site).
# `bunx convex dev` writes VITE_CONVEX_SITE_URL into .env.local. Uploads are screened
# by a server-side NSFW check — set OPENAI_API_KEY via `bunx convex env set`.
VITE_CONVEX_SITE_URL=

# ── Wallets ─────────────────────────────────────────────────────────────────
# WalletConnect Cloud project id — only needed for mobile/WalletConnect wallets.
# Injected wallets (MetaMask on desktop) work without it.
VITE_WALLETCONNECT_PROJECT_ID=
